# Raw dataset — 7 GB, public download (see README). Never committed.
# Leading slash = repo-root only, so it does NOT also ignore site/src/data/.
/data/

# Generated, rebuildable (converted labels, splits.json, materialised trees)
yolo_datasets/

# Per-run experiment outputs (weights, curves, metrics)
yolo_experiments/results/

# Remote-training artifacts + upload bundles (large, rebuildable; numbers live in
# RESULTS.md + the site). The kaggle/*.py scripts + README stay tracked.
colab/
upload/
kaggle/dataset/
kaggle/dataset.zip

# Pretrained weights — auto-downloaded by Ultralytics
*.pt

# Ultralytics stray val/predict outputs
runs/

# Python noise
__pycache__/
*.pyc

# Local Claude settings
.claude/settings.local.json
